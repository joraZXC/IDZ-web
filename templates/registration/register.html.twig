{% extends 'base.html.twig' %}

{% block body %}
<style>
    body {
        font-family: 'Arial', sans-serif;
        background-color: #e9ecef;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    .navbar {
        background-color: #444;
        color: white;
        padding: 10px 20px;
        text-align: center;
    }
    .navbar a {
        color: white;
        margin: 0 15px;
        text-decoration: none;
        font-size: 16px;
    }
    .navbar a:hover {
        text-decoration: underline;
    }
    .example-wrapper {
        margin: 20px auto;
        max-width: 800px;
        width: 95%;
        background-color: #fff;
        padding: 20px;
        border-radius: 5px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        flex-grow: 1;
    }
    h1 {
        color: #333;
        font-size: 24px;
        text-align: center;
        margin-bottom: 20px;
    }
    .form-group {
        margin-bottom: 15px;
    }
    label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
        color: #555;
    }
    input, select {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 14px;
    }
    button {
        background-color: #444;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        width: 100%;
        font-size: 16px;
    }
    button:hover {
        background-color: #333;
    }
    a {
        color: #007bff;
        text-decoration: none;
        font-size: 14px;
    }
    a:hover {
        text-decoration: underline;
    }
    .background-image {
        width: 100%;
        height: 200px;
        background-image: url('/images/mountains.jpg');
        background-size: cover;
        background-position: center;
        margin-top: 20px;
    }
</style>
<div class="navbar">
    <a href="{{ path('app_create_movie') }}">Добавить фильм</a>
    <a href="{{ path('app_create_screening') }}">Добавить сеанс</a>
    <a href="{{ path('app_logout') }}">Выход</a>
</div>
<div class="example-wrapper">
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <h1>Register</h1>

    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm) }}
        {{ form_row(registrationForm.email) }}
        {{ form_row(registrationForm.plainPassword, {
            label: 'Password'
        }) }}
        <button type="submit" class="btn">Добавить</button>
    {{ form_end(registrationForm) }}
    <div class="background-image"></div>
</div>
{% endblock %}