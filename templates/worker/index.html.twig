
{% block title %}{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper a { margin-right: 10px; }
    .alert { padding: 10px; margin: 10px 0; background-color: #d4edda; color: #155724; }
</style>
    <div>
        <a href="{{ path('app_logout') }}">Выход</a>
    </div>
<div class="example-wrapper">
    <h1>Клиен всегда прав!</h1>

    {% for flash in app.flashes('success') %}
        <div class="alert">{{ flash }}</div>
    {% endfor %}

    <p>
        <a href="{{ path('app_create_movie') }}">Добавить фильм</a>
        <a href="{{ path('app_create_screening') }}">Добавить сеанс</a>
    </p>
</div>
{% endblock %}